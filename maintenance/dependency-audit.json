{
  "enabled": true,
  "name": "Dependency Audit",
  "description": "When package.json is edited, audit dependencies for known vulnerabilities",
  "version": "1.0.0",
  "tags": ["security", "dependencies", "npm", "maintenance"],
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/package.json"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npm audit --audit-level=high"
  }
}
