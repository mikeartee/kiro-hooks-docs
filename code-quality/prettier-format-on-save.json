{
  "enabled": true,
  "name": "Prettier Format on Save",
  "description": "Run Prettier to auto-format files after editing to maintain consistent code style",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "**/*.css",
      "**/*.scss",
      "**/*.html"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx prettier --write \"${file}\""
  }
}
